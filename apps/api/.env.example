# Copy to .env and fill in real values. Never commit .env (gitignored).
# Local dev reads this file via tsx --env-file; on Netlify these are set as
# environment variables in the site's dashboard (the function reads process.env).

# Server. PORT is local-dev only — Netlify Functions don't bind a port.
PORT=3000
# 'development' locally; set NODE_ENV=production on Netlify (enables the Secure
# auth cookie, which Netlify's HTTPS requires).
NODE_ENV=development

# PostgreSQL connection string (Neon serverless, free tier).
# Format: postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require
# On Netlify use the Neon POOLED connection string (host contains "-pooler"):
# the function uses the WebSocket Pool driver, and pooling suits short-lived
# serverless invocations. Get it from Neon → Connection Details → "Pooled
# connection".
DATABASE_URL=

# Secret used to sign JWTs (jose). Use a long random string in production,
# e.g. `openssl rand -base64 32`.
JWT_SECRET=

# Origin allowed by CORS (auth uses an HttpOnly cookie with credentials).
# Local: the Vite dev server. On Netlify the API is same-origin with the SPA
# (served via the function), so set this to your deployed site URL,
# e.g. https://your-site.netlify.app
CORS_ORIGIN=http://localhost:5173
