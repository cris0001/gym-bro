# Copy to .env and adjust as needed. Vite only exposes VITE_-prefixed vars, and
# bakes them in at BUILD time (so on Netlify this must be set before `vite build`).

# Base URL of the @gym-bro/api backend.
#   Local dev: the API dev server (cross-origin) → http://localhost:3000
#   Netlify:   the API is same-origin (served by the /api/* function), so set
#              this to an EMPTY string so requests are relative ("/api/...").
#              Note: it must be set to "" — if left unset, the app falls back to
#              the localhost default, which is wrong in production.
VITE_API_URL=http://localhost:3000
